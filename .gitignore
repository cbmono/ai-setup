.DS_Store
tmp/

# .claude/ is symlinked from ~/.claude in the recommended install, so Claude Code
# writes all its runtime state (backups/, cache/, debug/, plugins/, projects/, …)
# in here. Ignore everything under .claude/ and explicitly allow only the tracked
# defaults — so present and future runtime folders never leak into git.
.claude/*

# Tracked defaults (directories — git recurses into re-included dirs)
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/skills/

# Tracked defaults (files)
!.claude/MEMORY.md
!.claude/README.md
!.claude/claude-defaults.md
!.claude/settings.json
!.claude/settings.mempalace.example.json
!.claude/settings.plugins.example.json

# Mempalace local index (if user opts in)
.mempalace/

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(git config --get:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(gh auth status)",
      "Bash(gh extension list)",
      "Bash(gh api:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh stack view:*)",
      "Bash(gh stack up:*)",
      "Bash(gh stack down:*)",
      "Bash(gh stack top:*)",
      "Bash(gh stack bottom:*)",
      "Bash(gh stack checkout:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx vitest:*)",
      "Bash(npx jest:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm exec:*)",
      "Bash(yarn install:*)",
      "Bash(yarn run:*)",
      "Bash(yarn test:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn eslint:*)",
      "Bash(yarn prettier:*)",
      "Bash(yarn vitest:*)",
      "Bash(yarn jest:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun install:*)",
      "Bash(bunx tsc:*)",
      "Bash(bunx eslint:*)",
      "Bash(bunx prettier:*)",
      "Bash(bunx vitest:*)",
      "Bash(bunx jest:*)",
      "Bash(node --version)",
      "Bash(coderabbit --help)",
      "Bash(coderabbit review:*)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "Bash(which:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.*.local)",
      "Read(**/id_rsa)",
      "Edit(**/id_rsa)",
      "Write(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(**/id_ed25519)",
      "Write(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Edit(**/id_ecdsa)",
      "Write(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Edit(**/id_dsa)",
      "Write(**/id_dsa)",
      "Read(**/.aws/credentials)",
      "Edit(**/.aws/credentials)",
      "Write(**/.aws/credentials)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-on-write.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
